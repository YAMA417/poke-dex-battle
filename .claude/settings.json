{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "enableAllProjectMcpServers": true,
  "outputStyle": "terse-dev",
  "plansDirectory": "./.claude/plans",
  "env": {
    "CLAUDE_AUTOCOMPACT_PCT_OVERRIDE": "80"
  },
  "attribution": {
    "commit": "Co-Authored-By: Claude <noreply@anthropic.com>",
    "pr": "Generated with [Claude Code](https://claude.com/claude-code)"
  },
  "permissions": {
    "allow": [
      "Bash(npm install)",
      "Bash(npm run:*)",
      "Bash(npm test:*)",
      "Bash(npx prettier:*)",
      "Bash(npx vitest:*)",
      "Bash(npx tsc:*)",
      "Bash(npx tsx:*)",
      "Bash(npx eslint:*)",
      "Bash(npx drizzle-kit:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)",
      "Bash(git switch:*)",
      "Bash(git checkout:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git fetch:*)",
      "Bash(git pull:*)",
      "Bash(git merge:*)",
      "Bash(git remote:*)",
      "Bash(gh pr:*)",
      "Bash(gh issue:*)",
      "Bash(gh api:*)",
      "Bash(codex exec:*)",
      "Bash(codex --version)",
      "Bash(codex doctor)",
      "Bash(command -v *)",
      "Bash(wc:*)",
      "WebSearch",
      "WebFetch(domain:raw.githubusercontent.com)",
      "WebFetch(domain:bulbapedia.bulbagarden.net)",
      "WebFetch(domain:bulbagarden.net)",
      "WebFetch(domain:play.pokemonshowdown.com)",
      "WebFetch(domain:wiki.xn--rckteqa2e.com)",
      "WebFetch(domain:champions.pokewiki.net)",
      "WebFetch(domain:game8.jp)",
      "WebFetch(domain:gamewith.jp)",
      "WebFetch(domain:xn--eckwa2aa3a9c8j8bve9d.gamewith.jp)",
      "WebFetch(domain:appmedia.jp)",
      "WebFetch(domain:mattari-kura.com)",
      "WebFetch(domain:www.serebii.net)"
    ],
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(rm -fr:*)",
      "Bash(sudo:*)",
      "Bash(git push origin main:*)",
      "Bash(git push origin main)",
      "Bash(git push:* main:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git reset --hard:*)",
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./packages/**/.env)",
      "Read(./packages/**/.env.*)",
      "Read(./apps/**/.env)",
      "Read(./apps/**/.env.*)",
      "Read(./backend/**/.env)",
      "Read(./backend/**/.env.*)",
      "Read(./.mcp.json)",
      "Edit(./.env)",
      "Edit(./.env.*)",
      "Write(./.env)",
      "Write(./.env.*)"
    ],
    "ask": [
      "Bash(npm install:*)",
      "Bash(npm uninstall:*)",
      "Bash(npm update:*)",
      "Bash(rm:*)",
      "Bash(rmdir:*)",
      "Bash(mv:*)",
      "Bash(git push:*)"
    ]
  },
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/stop-verify.sh",
            "timeout": 30000
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "npm run format 2>/dev/null || true",
            "timeout": 30000
          }
        ]
      }
    ]
  }
}
